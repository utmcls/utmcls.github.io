---
interface Props {
  title: string;
  description?: string;
  navLinks?: { href: string; label: string }[];
  sectionLinks?: { href: string; label: string; variant?: 'default' | 'cta' }[];
}

const {
  title,
  description = 'UTM Computational Linguistics Society',
  navLinks = [

  ],
  sectionLinks,
} = Astro.props;
import '../styles/global.css';
import Logo from '../components/Logo.astro';
import faviconLight from '../assets/favicon-light.png';
import faviconDark from '../assets/favicon-dark.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={faviconLight.src} />
    <link rel="icon" type="image/png" href={faviconDark.src} media="(prefers-color-scheme: dark)" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
  </head>
  <body class="bg-background text-foreground min-h-screen font-sans antialiased">
    <header class="sticky top-0 z-10 relative border-b border-border bg-background">
      <nav class="mx-auto flex max-w-6xl h-16 items-center justify-between gap-4 px-5" aria-label="Main">
        <Logo />
        <div class="hidden md:flex items-center gap-6">
          {navLinks.map((l) => (
            <a href={l.href} class="text-sm text-muted-foreground hover:text-foreground">{l.label}</a>
          ))}
        </div>
        <div class="md:hidden flex items-center gap-2">
          {!!navLinks?.length && (
            <button
              type="button"
              class="p-2 -m-2 text-muted-foreground hover:text-foreground aria-expanded:bg-muted rounded"
              aria-label="Open menu"
              aria-expanded="false"
              aria-controls="nav-menu"
              id="nav-toggle"
            >
              <img src="/icons/bars-solid-full.svg" alt="" class="w-6 h-6" width="24" height="24" loading="eager" />
            </button>
          )}
        </div>
      </nav>
      {!!navLinks?.length && (
        <div
          id="nav-menu"
          class="md:hidden hidden absolute top-full left-0 right-0 border-b border-border bg-background px-5 py-4 flex flex-col gap-3"
          aria-hidden="true"
        >
          {navLinks.map((l) => (
            <a href={l.href} class="text-sm text-muted-foreground hover:text-foreground nav-menu-link">{l.label}</a>
          ))}
        </div>
      )}
    </header>
    {!!sectionLinks?.length && (
      <>
        <div
          id="sections-overlay"
          class="md:hidden hidden fixed inset-0 bg-black/40 z-40"
          aria-hidden="true"
        />
        <aside
          id="sections-drawer"
          class="md:hidden fixed inset-x-0 bottom-0 max-h-[70vh] overflow-auto border-t border-border bg-background shadow-card transform translate-y-full transition-transform duration-200 ease-out rounded-t-2xl z-50"
          aria-label="Page sections"
          aria-hidden="true"
        >
          <div class="h-16 flex items-center justify-between gap-3 border-b border-border px-5">
            <p class="text-sm font-semibold text-foreground">Sections</p>
            <button
              type="button"
              class="inline-flex items-center justify-center rounded-lg border border-border bg-background size-10 text-muted-foreground hover:bg-muted hover:text-foreground"
              aria-label="Close sections"
              id="sections-close"
            >
              <img src="/icons/x-solid-full.svg" alt="" class="size-4" width="16" height="16" loading="eager" />
            </button>
          </div>
          <div class="px-5 py-4">
            <nav class="flex flex-col gap-1">
              {sectionLinks.map((l) => (
                l.variant === 'cta' ? (
                  <a
                    href={l.href}
                    class="mt-2 inline-flex items-center justify-center rounded-lg bg-accent px-4 py-2 text-sm font-medium text-accent-foreground hover:opacity-90 sections-link"
                  >
                    {l.label}
                  </a>
                ) : (
                  <a
                    href={l.href}
                    class="rounded-lg px-3 py-2 text-sm text-muted-foreground hover:bg-muted hover:text-foreground sections-link"
                  >
                    {l.label}
                  </a>
                )
              ))}
            </nav>
          </div>
        </aside>
        <button
          type="button"
          class="md:hidden fixed left-1/2 -translate-x-1/2 bottom-6 z-30 size-16 rounded-full border border-border bg-background shadow-card flex items-center justify-center text-muted-foreground hover:text-foreground hover:bg-muted aria-expanded:bg-muted"
          aria-label="Open table of contents"
          aria-expanded="false"
          aria-controls="sections-drawer"
          id="sections-toggle"
        >
          <img
            src="/icons/table-of-contents-black.svg"
            alt=""
            class="size-7"
            width="30"
            height="30"
            loading="eager"
          />
        </button>
      </>
    )}
    <script>
      const toggle = document.getElementById('nav-toggle');
      const menu = document.getElementById('nav-menu');
      const links = document.querySelectorAll('.nav-menu-link');
      if (toggle && menu) {
        toggle.addEventListener('click', () => {
          const open = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!open));
          menu.classList.toggle('hidden', open);
          menu.setAttribute('aria-hidden', String(open));
        });
        links.forEach((link) => {
          link.addEventListener('click', () => {
            toggle.setAttribute('aria-expanded', 'false');
            menu.classList.add('hidden');
            menu.setAttribute('aria-hidden', 'true');
          });
        });
      }

      const sectionsToggle = document.getElementById('sections-toggle');
      const sectionsDrawer = document.getElementById('sections-drawer');
      const sectionsOverlay = document.getElementById('sections-overlay');
      const sectionsClose = document.getElementById('sections-close');
      const sectionLinks = document.querySelectorAll('.sections-link');

      function setSectionsOpen(nextOpen: boolean) {
        if (!sectionsToggle || !sectionsDrawer || !sectionsOverlay) return;

        sectionsToggle.setAttribute('aria-expanded', String(nextOpen));
        sectionsDrawer.setAttribute('aria-hidden', String(!nextOpen));
        sectionsOverlay.setAttribute('aria-hidden', String(!nextOpen));
        document.body.classList.toggle('overflow-hidden', nextOpen);

        if (nextOpen) {
          sectionsOverlay.classList.remove('hidden');
          sectionsDrawer.classList.remove('translate-y-full');
          sectionsDrawer.classList.add('translate-y-0');
        } else {
          sectionsDrawer.classList.add('translate-y-full');
          sectionsDrawer.classList.remove('translate-y-0');
          sectionsOverlay.classList.add('hidden');
        }
      }

      if (sectionsToggle && sectionsDrawer && sectionsOverlay) {
        sectionsToggle.addEventListener('click', () => {
          const open = sectionsToggle.getAttribute('aria-expanded') === 'true';
          if (!open && toggle && menu) {
            toggle.setAttribute('aria-expanded', 'false');
            menu.classList.add('hidden');
            menu.setAttribute('aria-hidden', 'true');
          }
          setSectionsOpen(!open);
        });

        sectionsOverlay.addEventListener('click', () => setSectionsOpen(false));
        sectionsClose?.addEventListener('click', () => setSectionsOpen(false));

        sectionLinks.forEach((link) => {
          link.addEventListener('click', () => setSectionsOpen(false));
        });

        window.addEventListener('keydown', (e) => {
          if (e.key !== 'Escape') return;
          const open = sectionsToggle.getAttribute('aria-expanded') === 'true';
          if (open) setSectionsOpen(false);
        });
      }
    </script>
    {!!sectionLinks?.length && (
      <aside
        class="hidden md:block fixed left-0 top-16 bottom-0 w-60 border-r border-border bg-background"
        aria-label="Page sections"
      >
        <div class="h-full px-5 py-6">
          <p class="text-xs font-semibold tracking-wide text-muted-foreground">SECTIONS</p>
          <nav class="mt-4 flex flex-col gap-1">
            {sectionLinks.map((l) => (
              l.variant === 'cta' ? (
                <a
                  href={l.href}
                  class="mt-2 inline-flex items-center justify-center rounded-lg bg-accent px-4 py-2 text-sm font-medium text-accent-foreground hover:opacity-90"
                >
                  {l.label}
                </a>
              ) : (
                <a
                  href={l.href}
                  class="rounded-lg px-3 py-2 text-sm text-muted-foreground hover:bg-muted hover:text-foreground"
                >
                  {l.label}
                </a>
              )
            ))}
          </nav>
        </div>
      </aside>
    )}
    <div class={sectionLinks?.length ? 'md:pl-60' : ''}>
      <slot />
    </div>
  </body>
</html>
