---
import logo from '../assets/logo-black.svg';

interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<a href="/" class={`inline-flex items-center hover:opacity-90 ${className}`} aria-label="UTMCLS home">
  <img src={logo?.src} alt="UTMCLS" height={56} class="h-14 w-auto object-contain" />
</a>
